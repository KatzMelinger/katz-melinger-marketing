{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/connections/keepalive",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/calls/sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/forms/sync",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/leads/leakage/snapshot",
      "schedule": "30 6 * * 1"
    },
    {
      "path": "/api/seo/tracked-keywords/refresh",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/seo/opportunities/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/content/site-inventory/crawl",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/calls/score-pending",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/aeo/runs/start",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/agent/run",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/content/site-inventory/score",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/social/report/snapshot",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/social/metrics/refresh",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/seo/citations/weekly-audit",
      "schedule": "0 13 * * 1"
    }
  ]
}
